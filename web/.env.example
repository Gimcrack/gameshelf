NUXT_PUBLIC_API_BASE=http://localhost:8000
# Public GOG OAuth client id (not secret) — same value as api/.env's GOG_CLIENT_ID.
# Required to build a valid GOG login URL (B17/V54).
NUXT_PUBLIC_GOG_CLIENT_ID=
# Public Xbox (Azure AD app) client id (not secret) — same value as api/.env's
# XBOX_CLIENT_ID. Required to build a valid Xbox login URL (T63).
NUXT_PUBLIC_XBOX_CLIENT_ID=
